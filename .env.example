FLASK_SECRET_KEY=change-me-to-a-long-random-secret
DATABASE_URL=sqlite:///instance/backtestpro.db
POLYGON_API_KEY=
ENCRYPTION_KEY=

# Optional runtime flags
FLASK_DEBUG=0
PORT=5000
MAX_CONTENT_LENGTH=2097152
AUTO_CREATE_SCHEMA=1
ENABLE_SCHEDULER=0

# Set only if the frontend is hosted on a separate origin
CORS_ORIGINS=
SESSION_COOKIE_CROSS_SITE=0
SESSION_COOKIE_SECURE=0

# Optional admin bootstrap (recommended for first deploy only)
ADMIN_BOOTSTRAP_ENABLED=0
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin

# Email
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USERNAME=
MAILTRAP_PASSWORD=
MAIL_DEBUG=0
ENABLE_TEST_EMAIL_ROUTE=0

# OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Billing
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
